            <geometry>
                <mesh filename="../meshes/arm/base_link1.STL" 
                    scale="0.001 0.001 0.001" /> <!-- 4. 视觉模型缩放10倍（scale参数） -->
            </geometry>
            <material name="black">
                <color rgba="1 1 1 1" />
            </material>
        </visual>
        <collision>
            <origin xyz="-0.375 -0.375  -0.375" rpy="1.57 0 1.57" />
            <geometry>
