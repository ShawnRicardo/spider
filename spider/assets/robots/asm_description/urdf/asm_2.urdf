        </collision>
    </link>
     <joint name="pestal_joint" type="fixed">
        <origin xyz="0 0 0" rpy="0 0 0" />  
        <parent link="base_link" />
        <child link="pestal_link" />
        <axis xyz="0 0 0" />
     </joint>

