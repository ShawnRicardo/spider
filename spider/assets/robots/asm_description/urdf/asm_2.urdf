                    scale="0.001 0.001 0.001" /> <!-- 4. 视觉模型缩放10倍（scale参数） -->
            </geometry>
        </collision>
    </link>
    <link name="pestal_link">
        <visual>
            <origin xyz="-0.085 -0.085 1.05" rpy="0 0 0" />
            <geometry>
                <mesh filename="../meshes/arm/base_link2.STL" 
                    scale="0.001 0.001 0.001" /> <!-- 4. 视觉模型缩放10倍（scale参数） -->
